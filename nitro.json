{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["iroh"],
  "ios": {
    "iosModuleName": "Iroh"
  },
  "android": {
    "androidNamespace": ["iroh"],
    "androidCxxLibName": "Iroh"
  },
  "rust": {
    "implCrate": "iroh-rn-core"
  },
  "autolinking": {
    "Iroh": {
      "rust": "HybridIroh"
    }
  },
  "ignorePaths": ["**/node_modules"]
}
