{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "iroh"
  ],
  "ios": {
    "iosModuleName": "Iroh"
  },
  "android": {
    "androidNamespace": [
      "iroh"
    ],
    "androidCxxLibName": "Iroh"
  },
  "autolinking": {
    "Iroh": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridIroh"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}